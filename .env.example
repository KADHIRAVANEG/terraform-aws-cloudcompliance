# CloudCompliance — Environment Variables Example
# Copy this file to .env and fill in your values
# cp .env.example .env

# NVIDIA NIM API Key (required for 'cloudcompliance ask' command)
# Get yours at: https://build.nvidia.com
NVIDIA_API_KEY=#-------------your-nvidia-nim-key-here----------------------#

# GitHub Personal Access Token (required for auto-remediation)
# Scopes needed: repo (full control of private repositories)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=#------------your-github-token-here-----------------------#

# GitHub repository for auto-remediation PRs (owner/repo format)
#GITHUB_REPO=KADHIRAVANEG/cloudcompliance
GITHUB_REPO=#---------your-repo-here-----------------------#

# LocalStack endpoint for local development
# Change to "" for real AWS deployment
LOCALSTACK_ENDPOINT=http://localhost:4566
